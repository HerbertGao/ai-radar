{
  "name": "ai-radar",
  "version": "0.0.0",
  "private": true,
  "description": "AI 行业情报流水线 + AI 工具选型顾问",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "start": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "migrate": "drizzle-kit migrate",
    "worker": "tsx src/pipeline/worker-main.ts",
    "mr:browser-worker": "tsx src/mr/scrape/browser-worker-main.ts",
    "mcp": "tsx src/mcp/server.ts",
    "smoke": "tsx src/pipeline/smoke.ts",
    "kb:backfill": "tsx src/kb/backfill-main.ts",
    "kb:search": "tsx src/kb/search-cli.ts",
    "mr:seed": "tsx src/mr/ingest/seed-main.ts",
    "spec:validate": "openspec-cn validate --strict",
    "prepare": "git config core.hooksPath .githooks || true",
    "spec:body-superset": "node scripts/spec-body-superset.mjs"
  },
  "dependencies": {
    "@ai-sdk/openai": "^3.0.74",
    "@hono/node-server": "^2.0.6",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "ai": "^7.0.17",
    "bullmq": "^5.79.2",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "emoji-regex": "^10.6.0",
    "grammy": "^1.44.0",
    "hono": "^4.12.28",
    "ioredis": "^5.11.1",
    "opencc-js": "^1.4.1",
    "pg": "^8.22.0",
    "playwright": "^1.61.1",
    "rss-parser": "^3.13.0",
    "youtube-transcript": "^1.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@herbertgao/openspec-cn": "1.6.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.6.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.9"
  }
}
